# pi-gen config for the KODE OS v0.2.0-alpha bootable image (Pi 5).
#
# pi-gen sources this file as bash. Anything build.sh exports before
# invoking pi-gen lands here; the ${KODE_*:-default} pattern lets the
# slim + bundled-apps build variants share one config file.
#
# Reference: https://github.com/RPi-Distro/pi-gen/blob/master/README.md

# Artifact name — build.sh sets KODE_IMG_NAME to either
# `kode-os-v0.2.0-alpha-pi5` (slim, the default) or
# `kode-os-v0.2.0-alpha-pi5-with-apps` (bundled).
IMG_NAME="${KODE_IMG_NAME:-kode-os-v0.2.0-alpha-pi5}"

# Pi 5 Bookworm 64-bit. Matches what install.sh has been tested
# against and what the kode-os-ui + casaos-gateway expect.
RELEASE="bookworm"
ARCH="arm64"
ARCHIVE_ROOT="https://archive.raspberrypi.com/debian/"

# Hostname matches what every doc + the OLED daemon assume. Buyers
# can rename in the wizard later; this is just the boot default.
TARGET_HOSTNAME="pebble"

LOCALE_DEFAULT="en_US.UTF-8"
KEYBOARD_KEYMAP="us"
KEYBOARD_LAYOUT="English (US)"
TIMEZONE_DEFAULT="UTC"

# The `kode` user exists for systemd group ownership (the OLED
# daemon runs as `kode`) — NOT for login. We don't want ANY usable
# account until the wizard creates one.
#
# Pi-gen refuses to combine empty FIRST_USER_PASS with
# DISABLE_FIRST_BOOT_USER_RENAME=1 (it sees that as "ship a known
# empty password without forcing the user to change it" = exploit).
# Workaround: build.sh exports a fresh random password per build
# (different on every image), and install-in-chroot.sh runs
# `passwd -l kode` immediately after pi-gen sets it. End state:
#   - kode account exists, in the right groups
#   - account is LOCKED — no login possible via password
#   - SSH is disabled anyway (ENABLE_SSH=0)
#   - the random password is never written to disk in cleartext
#     and never shipped — it dies with build.sh's process.
FIRST_USER_NAME="kode"
FIRST_USER_PASS="${KODE_FIRST_USER_PASS:-PLACEHOLDER_BUILD_SH_MUST_EXPORT_THIS}"
DISABLE_FIRST_BOOT_USER_RENAME=1

# SSH defaults OFF (released-image security model). build.sh's
# --debug-ssh flag flips KODE_ENABLE_SSH=1 and exports the host's
# pubkey via KODE_SSH_PUBKEY so the maintainer can ssh kode@... for
# debugging. The kode account stays passwd -l locked either way;
# only pubkey auth ever works.
ENABLE_SSH="${KODE_ENABLE_SSH:-0}"
PUBKEY_ONLY_SSH=1
PUBKEY_SSH_FIRST_USER="${KODE_SSH_PUBKEY:-}"

APT_PROXY=""
SETFCAP=1
PI_GEN_RELEASE="KODE OS v0.2.0-alpha (pi5)"

# Output as .img.xz at max compression. Adds a few minutes to the
# build but shaves hundreds of MB off the artifact buyers download.
DEPLOY_COMPRESSION="xz"
COMPRESSION_LEVEL=9

# Force stage order. Pi-gen's auto-detect runs `stage*` directories
# in lexicographic order, but `stage-kode-os` sorts BEFORE `stage0`
# (the `-` byte is 0x2D, `0` is 0x30) — so our stage would fire
# first with no base rootfs to layer on top of. STAGE_LIST overrides
# that. We also drop the desktop stages here even though build.sh
# touches SKIP files in them; STAGE_LIST makes the skip explicit.
STAGE_LIST="stage0 stage1 stage2 stage-kode-os"
